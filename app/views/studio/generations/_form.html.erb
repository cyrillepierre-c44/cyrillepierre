<%= form_for generation, url: url,
              html: { multipart: true,
                      data: { controller: "studio-generation", turbo: false, action: "submit->studio-generation#submitting" } } do |f| %>
  <%= render "devise/shared/error_messages", resource: generation %>

  <div class="studio-progress-overlay d-none" data-studio-generation-target="overlay">
    <div class="studio-progress-box">
      <p class="studio-progress-text" data-studio-generation-target="progressText">Génération en cours…</p>
      <div class="studio-progress-bar"><div class="studio-progress-bar-fill"></div></div>
      <p class="studio-progress-hint">Ça peut prendre jusqu'à une minute selon la source fournie.</p>
    </div>
  </div>

  <div class="studio-card">
    <h2 class="studio-card-subtitle">1. Type de contenu</h2>
    <div class="cf-themes-grid studio-kind-grid">
      <label class="cf-theme-card">
        <%= f.radio_button :kind, "linkedin_post", checked: generation.kind.blank? || generation.linkedin_post?,
                            data: { action: "change->studio-generation#selectKind" } %>
        <div class="cf-theme-inner">
          <span class="cf-theme-icon">💼</span>
          <h3 class="cf-theme-title">Post LinkedIn</h3>
          <p class="cf-theme-desc">Un post court et percutant à partir d'une source</p>
          <span class="cf-theme-check"><i class="fa-solid fa-check"></i></span>
        </div>
      </label>

      <label class="cf-theme-card">
        <%= f.radio_button :kind, "cover_letter", checked: generation.cover_letter?,
                            data: { action: "change->studio-generation#selectKind" } %>
        <div class="cf-theme-inner">
          <span class="cf-theme-icon">✉️</span>
          <h3 class="cf-theme-title">Lettre de motivation</h3>
          <p class="cf-theme-desc">Ciblée sur une offre d'emploi ou de mission précise</p>
          <span class="cf-theme-check"><i class="fa-solid fa-check"></i></span>
        </div>
      </label>

      <label class="cf-theme-card">
        <%= f.radio_button :kind, "commercial_proposal", checked: generation.commercial_proposal?,
                            data: { action: "change->studio-generation#selectKind" } %>
        <div class="cf-theme-inner">
          <span class="cf-theme-icon">📋</span>
          <h3 class="cf-theme-title">Proposition commerciale</h3>
          <p class="cf-theme-desc">En réponse à un brief client</p>
          <span class="cf-theme-check"><i class="fa-solid fa-check"></i></span>
        </div>
      </label>

      <label class="cf-theme-card">
        <%= f.radio_button :kind, "site_actu", checked: generation.site_actu?,
                            data: { action: "change->studio-generation#selectKind" } %>
        <div class="cf-theme-inner">
          <span class="cf-theme-icon">📰</span>
          <h3 class="cf-theme-title">Actu du site</h3>
          <p class="cf-theme-desc">Une actualité publiable sur /actus</p>
          <span class="cf-theme-check"><i class="fa-solid fa-check"></i></span>
        </div>
      </label>
    </div>
  </div>

  <div class="studio-card">
    <h2 class="studio-card-subtitle">2. Orientation</h2>
    <div class="cf-field">
      <%= f.select :orientation,
                    Generation::ORIENTATION_LABELS.map { |value, label| [label, value] },
                    { selected: generation.orientation.presence || "consultant" },
                    class: "cf-input" %>
      <p class="studio-field-hint">Surtout utile pour les posts LinkedIn — change le ton et l'appel à l'action.</p>
    </div>
  </div>

  <div class="studio-card d-none" data-studio-generation-target="realisationField">
    <h2 class="studio-card-subtitle">Réalisation à mettre en avant (optionnel)</h2>
    <div class="cf-field">
      <%= f.select :realisation_id,
                    options_for_select(
                      [["Laisser l'IA choisir", ""]] +
                      RealisationCatalog::ITEMS.map { |r| ["#{r[:id]} — #{r[:titre]}", r[:id]] },
                      generation.realisation_id
                    ), {}, class: "cf-input" %>
      <p class="studio-field-hint">
        Si tu colles une source ou un brief, l'IA choisit elle-même la réalisation la plus pertinente — ce
        sélecteur n'impose un choix que pour les posts générés sans source.
      </p>
    </div>

    <% if local_assigns.fetch(:show_generate_visual_option, false) %>
      <div class="cf-field cf-field--checkbox">
        <label>
          <%= f.check_box :generate_visual %>
          Générer aussi un visuel juste après le texte
        </label>
      </div>
    <% end %>
  </div>

  <div class="studio-card">
    <h2 class="studio-card-subtitle">3. Titre (optionnel)</h2>
    <div class="cf-field">
      <%= f.text_field :title, class: "cf-input", placeholder: "Donne un nom à cette génération" %>
    </div>
  </div>

  <div class="studio-card">
    <h2 class="studio-card-subtitle">4. Modèle IA</h2>
    <div class="cf-field">
      <%= f.select :llm_model,
                    Generation::LLM_MODELS.map { |value, (label, _provider)| [label, value] },
                    { selected: generation.llm_model.presence || "gpt-4o" },
                    class: "cf-input" %>
    </div>
  </div>

  <div class="studio-card">
    <h2 class="studio-card-subtitle">5. Source</h2>

    <div class="studio-source-tabs" role="tablist">
      <button type="button" class="studio-source-tab studio-source-tab--active"
              data-studio-generation-target="tabButton" data-source="text"
              data-action="click->studio-generation#selectSource">Texte collé</button>
      <button type="button" class="studio-source-tab"
              data-studio-generation-target="tabButton" data-source="file"
              data-action="click->studio-generation#selectSource">Fichier</button>
      <button type="button" class="studio-source-tab"
              data-studio-generation-target="tabButton" data-source="url"
              data-action="click->studio-generation#selectSource">URL</button>
    </div>

    <div class="cf-field studio-source-panel" data-studio-generation-target="sourcePanel" data-source="text">
      <%= f.text_area :input_text, class: "cf-input cf-textarea", rows: 8, placeholder: "Colle ici le texte source (brief, offre d'emploi, notes…)" %>
      <p class="studio-field-hint">
        Laisse vide pour que l'IA invente un post à partir du profil de Cyrille (CV, réalisations).
      </p>
    </div>

    <div class="cf-field studio-source-panel d-none" data-studio-generation-target="sourcePanel" data-source="file">
      <%= f.file_field :source_file, class: "cf-input", accept: ".txt,.md,.pdf" %>
      <p class="studio-field-hint">Formats acceptés : .txt, .md, .pdf — 10 Mo maximum</p>
    </div>

    <div class="cf-field studio-source-panel d-none" data-studio-generation-target="sourcePanel" data-source="url">
      <%= f.url_field :input_url, class: "cf-input", placeholder: "https://exemple.com/offre-emploi" %>
    </div>
  </div>

  <div class="studio-card">
    <h2 class="studio-card-subtitle">6. Instructions complémentaires (optionnel)</h2>
    <div class="cf-field">
      <%= f.text_area :extra_instructions, class: "cf-input cf-textarea", rows: 3, placeholder: "Ton à adopter, points à mettre en avant…" %>
    </div>
  </div>

  <div class="studio-actions">
    <%= link_to "Annuler", studio_generations_path, class: "btn-cp-outline" %>
    <%= f.submit submit_label, class: "btn-cp-primary", data: { studio_generation_target: "submitButton" } %>
  </div>
<% end %>
