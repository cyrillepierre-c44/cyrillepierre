<% content_for :title, (@generation.title.presence || "Génération") + " — Studio" %>

<section class="service-hero">
  <div class="container">
    <span class="section-eyebrow"><%= @generation.kind.humanize %></span>

    <% if policy(@generation).update? %>
      <div data-controller="studio-output-edit">
        <h1 class="studio-editable-title" data-studio-output-edit-target="display"
            data-action="click->studio-output-edit#edit" title="Cliquer pour modifier le titre">
          <%= @generation.title.presence || "Génération sans titre" %>
        </h1>

        <div class="d-none" data-studio-output-edit-target="form">
          <%= form_for @generation, url: studio_generation_path(@generation), method: :patch,
                        html: { id: "studio-title-edit-form", data: { turbo: false } } do |f| %>
            <%= f.text_field :title, class: "cf-input studio-title-input", placeholder: "Titre de la génération" %>
            <div class="studio-actions mt-2">
              <button type="button" class="btn-cp-outline" data-action="studio-output-edit#cancel">Annuler</button>
              <%= f.submit "Enregistrer", class: "btn-cp-primary" %>
            </div>
          <% end %>
        </div>
      </div>
    <% else %>
      <h1><%= @generation.title.presence || "Génération sans titre" %></h1>
    <% end %>
  </div>
</section>

<div class="container pb-5">
  <div class="studio-card">
    <div class="studio-show-toolbar">
      <div class="studio-show-badges">
        <span class="studio-badge studio-badge--status-<%= @generation.status %>"><%= @generation.status.humanize %></span>
        <span class="studio-badge studio-badge--model">
          <%= Generation::LLM_MODELS.dig(@generation.llm_model, 0) || @generation.llm_model %>
        </span>
        <% if @generation.realisation_id.present? %>
          <span class="studio-badge" title="Réalisation utilisée pour ce post">
            <%= @generation.realisation_id %>
          </span>
        <% end %>
      </div>

      <div class="studio-actions">
        <%= form_for @generation, url: regenerate_studio_generation_path(@generation), method: :patch,
                      html: { class: "studio-regenerate-form",
                              data: { controller: "studio-generation", turbo: false,
                                      action: "submit->studio-generation#submitting" } } do |f| %>
          <div class="studio-progress-overlay d-none" data-studio-generation-target="overlay">
            <div class="studio-progress-box">
              <p class="studio-progress-text">Génération en cours…</p>
              <div class="studio-progress-bar"><div class="studio-progress-bar-fill"></div></div>
              <p class="studio-progress-hint">Ça peut prendre jusqu'à une minute selon la source fournie.</p>
            </div>
          </div>

          <%= f.select :llm_model, Generation::LLM_MODELS.map { |value, (label, _provider)| [label, value] },
                        { selected: @generation.llm_model }, class: "cf-input studio-regenerate-select" %>
          <%= f.submit "Régénérer", class: "btn-cp-outline", data: { studio_generation_target: "submitButton" } %>
        <% end %>

        <% if policy(@generation).publish? && !@generation.published? %>
          <%= button_to "Publier sur /actus", publish_studio_generation_path(@generation), method: :patch, class: "btn-cp-primary" %>
        <% elsif policy(@generation).unpublish? && @generation.published? %>
          <%= button_to "Dépublier", unpublish_studio_generation_path(@generation), method: :patch, class: "btn-cp-outline" %>
        <% end %>

        <% if policy(@generation).destroy? %>
          <%= button_to "Supprimer", studio_generation_path(@generation), method: :delete,
                         class: "btn-cp-outline studio-btn-danger",
                         data: { turbo_confirm: "Supprimer cette génération ?" } %>
        <% end %>
      </div>
    </div>

    <% if @generation.output.blank? %>
      <p class="studio-empty">Pas encore de contenu généré.</p>
    <% else %>
      <div data-controller="studio-output-edit">
        <div data-studio-output-edit-target="display">
          <% if @generation.structured_output? %>
            <% @generation.sections.each do |key, content| %>
              <div class="studio-section" data-controller="studio-clipboard">
                <div class="studio-section-header">
                  <h3 class="studio-section-title"><%= Generation::SECTION_LABELS.fetch(key, key.to_s.humanize) %></h3>
                  <button type="button" class="btn-cp-outline btn-cp-sm" data-action="studio-clipboard#copy">Copier</button>
                </div>
                <pre class="studio-output" data-studio-clipboard-target="source"><%= content %></pre>
              </div>
            <% end %>
          <% elsif @generation.linkedin_post? %>
            <% formatted_post = LinkedinTextFormatter.call(@generation.output) %>
            <div class="studio-linkedin-preview">
              <div class="studio-linkedin-preview-header">
                <img src="/images/cyrille.jpg" alt="Cyrille PIERRE" class="studio-linkedin-preview-avatar">
                <div>
                  <div class="studio-linkedin-preview-name">Cyrille PIERRE</div>
                  <div class="studio-linkedin-preview-headline">
                    Consultant indépendant · Management de transition, Excellence opérationnelle &amp; Tech/IA
                  </div>
                </div>
              </div>
              <p class="studio-linkedin-preview-body"><%= formatted_post %></p>
            </div>

            <div class="studio-section-header studio-section-header--end mt-3" data-controller="studio-clipboard">
              <button type="button" class="btn-cp-outline btn-cp-sm" data-action="studio-clipboard#copy">Copier</button>
              <pre class="d-none" data-studio-clipboard-target="source"><%= formatted_post %></pre>
            </div>
          <% else %>
            <div data-controller="studio-clipboard">
              <div class="studio-section-header studio-section-header--end">
                <button type="button" class="btn-cp-outline btn-cp-sm" data-action="studio-clipboard#copy">Copier</button>
              </div>
              <pre class="studio-output" data-studio-clipboard-target="source"><%= @generation.output %></pre>
            </div>
          <% end %>

          <% if policy(@generation).update? %>
            <div class="studio-section-header--end mt-2">
              <button type="button" class="btn-cp-outline btn-cp-sm" data-action="studio-output-edit#edit">
                ✎ Modifier le texte
              </button>
            </div>
          <% end %>
        </div>

        <% if policy(@generation).update? %>
          <div class="d-none" data-studio-output-edit-target="form">
            <%= form_for @generation, url: studio_generation_path(@generation), method: :patch,
                          html: { id: "studio-output-edit-form", data: { turbo: false } } do |f| %>
              <%= f.text_area :output, class: "cf-input cf-textarea", rows: 14 %>
              <div class="studio-actions mt-2">
                <button type="button" class="btn-cp-outline" data-action="studio-output-edit#cancel">Annuler</button>
                <%= f.submit "Enregistrer", class: "btn-cp-primary" %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <% if @generation.linkedin_post? && @generation.output.present? %>
    <div class="studio-card">
      <h2 class="studio-card-subtitle">Visuel</h2>

      <% if @generation.visual.attached? %>
        <%= image_tag @generation.visual, class: "studio-visual-preview" %>
      <% else %>
        <p class="studio-card-sub">Pas encore de visuel généré pour ce post.</p>
      <% end %>

      <% if policy(@generation).generate_visual? %>
        <%= form_for @generation, url: generate_visual_studio_generation_path(@generation), method: :patch,
                      html: { data: { controller: "studio-generation", turbo: false,
                                      action: "submit->studio-generation#submitting" } } do |f| %>
          <div class="studio-progress-overlay d-none" data-studio-generation-target="overlay">
            <div class="studio-progress-box">
              <p class="studio-progress-text">Génération du visuel en cours…</p>
              <div class="studio-progress-bar"><div class="studio-progress-bar-fill"></div></div>
              <p class="studio-progress-hint">Ça peut prendre jusqu'à une minute.</p>
            </div>
          </div>

          <%= f.submit @generation.visual.attached? ? "Régénérer le visuel" : "Générer un visuel",
                        class: "btn-cp-outline studio-visual-action mt-2",
                        data: { studio_generation_target: "submitButton" } %>
        <% end %>
      <% end %>

      <% if @generation.linkedin_published_at.present? %>
        <p class="studio-card-sub mt-3">
          ✓ Publié sur LinkedIn le <%= @generation.linkedin_published_at.strftime("%d/%m/%Y à %H:%M") %>
          <% if @generation.linkedin_post_url.present? %>
            — <%= link_to "voir le post", @generation.linkedin_post_url, target: "_blank", rel: "noopener" %>
          <% end %>
        </p>
      <% end %>

      <% if policy(@generation).publish_to_linkedin? %>
        <% if current_user.linkedin_connected? %>
          <%= form_for @generation, url: publish_to_linkedin_studio_generation_path(@generation), method: :patch,
                        html: { class: "mt-2", data: { controller: "studio-generation", turbo: false,
                                        action: "submit->studio-generation#submitting" } } do |f| %>
            <div class="studio-progress-overlay d-none" data-studio-generation-target="overlay">
              <div class="studio-progress-box">
                <p class="studio-progress-text">Publication sur LinkedIn en cours…</p>
                <div class="studio-progress-bar"><div class="studio-progress-bar-fill"></div></div>
              </div>
            </div>

            <%= f.submit @generation.linkedin_published_at.present? ? "Republier sur LinkedIn" : "Publier sur LinkedIn",
                          class: "btn-cp-primary studio-visual-action",
                          data: { studio_generation_target: "submitButton" } %>
          <% end %>
        <% else %>
          <p class="studio-card-sub mt-2">
            <%= link_to "Connecter mon compte LinkedIn", linkedin_auth_connect_path, class: "btn-cp-outline" %>
            pour pouvoir publier directement.
          </p>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <div class="studio-card">
    <h2 class="studio-card-subtitle">Sources</h2>
    <dl class="studio-sources-list">
      <% if @generation.input_text.present? %>
        <dt>Texte collé</dt>
        <dd class="studio-sources-pre"><%= @generation.input_text %></dd>
      <% end %>
      <% if @generation.input_url.present? %>
        <dt>URL</dt>
        <dd><%= @generation.input_url %></dd>
      <% end %>
      <% if @generation.source_file.attached? %>
        <dt>Fichier</dt>
        <dd><%= @generation.source_file.filename %></dd>
      <% end %>
      <% if @generation.extra_instructions.present? %>
        <dt>Instructions complémentaires</dt>
        <dd class="studio-sources-pre"><%= @generation.extra_instructions %></dd>
      <% end %>
    </dl>
  </div>

  <%= link_to "← Retour à la liste", studio_generations_path, class: "studio-back-link" %>
</div>
