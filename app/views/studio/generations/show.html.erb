<% content_for :title, (@generation.title.presence || "Génération") + " — Studio" %>

<section class="service-hero">
  <div class="container">
    <span class="section-eyebrow"><%= @generation.kind.humanize %></span>
    <h1><%= @generation.title.presence || "Génération sans titre" %></h1>
  </div>
</section>

<div class="container pb-5">
  <div class="studio-card">
    <div class="studio-show-toolbar">
      <div class="studio-show-badges">
        <span class="studio-badge studio-badge--status-<%= @generation.status %>"><%= @generation.status.humanize %></span>
        <span class="studio-badge studio-badge--model">
          <%= Generation::LLM_MODELS.dig(@generation.llm_model, 0) || @generation.llm_model %>
        </span>
      </div>

      <div class="studio-actions">
        <%= form_for @generation, url: regenerate_studio_generation_path(@generation), method: :patch,
                      html: { class: "studio-regenerate-form",
                              data: { controller: "studio-generation", turbo: false,
                                      action: "submit->studio-generation#submitting" } } do |f| %>
          <div class="studio-progress-overlay d-none" data-studio-generation-target="overlay">
            <div class="studio-progress-box">
              <p class="studio-progress-text">Génération en cours…</p>
              <div class="studio-progress-bar"><div class="studio-progress-bar-fill"></div></div>
              <p class="studio-progress-hint">Ça peut prendre jusqu'à une minute selon la source fournie.</p>
            </div>
          </div>

          <%= f.select :llm_model, Generation::LLM_MODELS.map { |value, (label, _provider)| [label, value] },
                        { selected: @generation.llm_model }, class: "cf-input studio-regenerate-select" %>
          <%= f.submit "Régénérer", class: "btn-cp-outline", data: { studio_generation_target: "submitButton" } %>
        <% end %>

        <% if policy(@generation).publish? && !@generation.published? %>
          <%= button_to "Publier sur /actus", publish_studio_generation_path(@generation), method: :patch, class: "btn-cp-primary" %>
        <% elsif policy(@generation).unpublish? && @generation.published? %>
          <%= button_to "Dépublier", unpublish_studio_generation_path(@generation), method: :patch, class: "btn-cp-outline" %>
        <% end %>

        <% if policy(@generation).destroy? %>
          <%= button_to "Supprimer", studio_generation_path(@generation), method: :delete,
                         class: "btn-cp-outline studio-btn-danger",
                         data: { turbo_confirm: "Supprimer cette génération ?" } %>
        <% end %>
      </div>
    </div>

    <% if @generation.output.blank? %>
      <p class="studio-empty">Pas encore de contenu généré.</p>
    <% elsif @generation.structured_output? %>
      <% @generation.sections.each do |key, content| %>
        <div class="studio-section" data-controller="studio-clipboard">
          <div class="studio-section-header">
            <h3 class="studio-section-title"><%= Generation::SECTION_LABELS.fetch(key, key.to_s.humanize) %></h3>
            <button type="button" class="btn-cp-outline btn-cp-sm" data-action="studio-clipboard#copy">Copier</button>
          </div>
          <pre class="studio-output" data-studio-clipboard-target="source"><%= content %></pre>
        </div>
      <% end %>
    <% else %>
      <div data-controller="studio-clipboard">
        <div class="studio-section-header studio-section-header--end">
          <button type="button" class="btn-cp-outline btn-cp-sm" data-action="studio-clipboard#copy">Copier</button>
        </div>
        <pre class="studio-output" data-studio-clipboard-target="source"><%= @generation.output %></pre>
      </div>
    <% end %>
  </div>

  <div class="studio-card">
    <h2 class="studio-card-subtitle">Sources</h2>
    <dl class="studio-sources-list">
      <% if @generation.input_text.present? %>
        <dt>Texte collé</dt>
        <dd><%= truncate(@generation.input_text, length: 300) %></dd>
      <% end %>
      <% if @generation.input_url.present? %>
        <dt>URL</dt>
        <dd><%= @generation.input_url %></dd>
      <% end %>
      <% if @generation.source_file.attached? %>
        <dt>Fichier</dt>
        <dd><%= @generation.source_file.filename %></dd>
      <% end %>
      <% if @generation.extra_instructions.present? %>
        <dt>Instructions complémentaires</dt>
        <dd><%= @generation.extra_instructions %></dd>
      <% end %>
    </dl>
  </div>

  <%= link_to "← Retour à la liste", studio_generations_path, class: "studio-back-link" %>
</div>
