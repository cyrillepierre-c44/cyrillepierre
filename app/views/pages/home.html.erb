        </a>
      </div>

    </div>
  </div>
</section>

<%# ============================== CTA ============================== %>
<section data-controller="reveal">
  <div class="container">
    <div class="cta-block reveal">
      <span class="section-eyebrow">Contact</span>
      <h2>Parlons de votre projet</h2>
      <p>Vous avez une problématique opérationnelle, un projet de transformation ou un outil à construire ? Je suis disponible pour un premier échange sans engagement.</p>
      <div class="cta-actions">
        <a href="<%= contact_path %>" class="btn-cp-primary">M'écrire directement</a>
        <a href="https://www.linkedin.com/in/cyrille-pierre" target="_blank" rel="noopener" class="btn-cp-outline">LinkedIn</a>
