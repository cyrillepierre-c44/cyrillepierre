<%# ============================== SERVICES PREVIEW ============================== %>
<section class="services-preview-section" data-controller="reveal">
  <div class="container">
    <div class="row g-0 mb-4 reveal">
      <div class="col-12">
        <span class="section-eyebrow">Mes domaines d'intervention</span>
        <h2 class="section-title">Comment puis-je vous aider ?</h2>
      </div>
    </div>
    <div class="row g-4">

      <div class="col-md-4 reveal reveal-delay-1">
        <a href="<%= operations_path %>" class="preview-card">
          <span class="preview-icon">⚙️</span>
          <h3>Excellence Opérationnelle</h3>
          <p>Diagnostic de vos pertes, déploiement Lean & KAIZEN, mise en place d'indicateurs — avec des résultats mesurables dès les premières semaines.</p>
          <span class="preview-link">Voir cette expertise →</span>
        </a>
      </div>

      <div class="col-md-4 reveal reveal-delay-2">
        <a href="<%= leadership_path %>" class="preview-card">
