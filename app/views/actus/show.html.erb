<% content_for :title, (@actu.title.presence || "Actu") + " — Cyrille PIERRE" %>

<section class="service-hero">
  <div class="container">
    <span class="section-eyebrow"><%= @actu.published_at.strftime("%d/%m/%Y") %></span>
    <h1><%= @actu.title.presence || "Actualité" %></h1>
  </div>
</section>

<div class="container pb-5">
  <div class="actu-body">
    <%= simple_format(@actu.output) %>
  </div>

  <%= link_to "← Toutes les actus", actus_path, class: "studio-back-link" %>
</div>
