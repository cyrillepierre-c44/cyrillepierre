<!DOCTYPE html>
<html lang="fr">
  <head>
    <title><%= content_for(:title) || "Cyrille PIERRE — Consultant Opérationnel & Tech" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="Cyrille PIERRE — Consultant indépendant en excellence opérationnelle et transformation digitale. Ingénieur Arts & Métiers, 20 ans d'expérience industrielle. Lyon.">
    <meta property="og:type"        content="website">
    <meta property="og:site_name"   content="Cyrille PIERRE">
    <meta property="og:locale"      content="fr_FR">
    <meta property="og:title"       content="<%= content_for(:title) || "Cyrille PIERRE — Consultant Opérationnel & Tech" %>">
    <meta property="og:description" content="Consultant indépendant en excellence opérationnelle et transformation digitale. Ingénieur Arts & Métiers, 20 ans d'expérience industrielle. Lyon.">
    <meta property="og:url"         content="https://www.cyrillepierre.com<%= request.path %>">
    <meta property="og:image"       content="https://www.cyrillepierre.com/images/og-image.jpg">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta name="twitter:card"       content="summary_large_image">
    <meta name="twitter:title"      content="<%= content_for(:title) || "Cyrille PIERRE — Consultant Opérationnel & Tech" %>">
    <meta name="twitter:image"      content="https://www.cyrillepierre.com/images/og-image.jpg">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="/icon.png?v=2" type="image/png">
    <link rel="apple-touch-icon" href="/apple-touch-icon-v2.png">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#050a15">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= yield :head %>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-cp fixed-top">
      <div class="container">
        <% if current_page?(root_path) %>
          <a class="navbar-linkedin" href="https://www.linkedin.com/in/cyrille-pierre" target="_blank" rel="noopener" title="LinkedIn">
            <i class="fa-brands fa-linkedin"></i>
          </a>
        <% else %>
          <a class="navbar-brand navbar-avatar-link" href="<%= root_path %>" title="Retour au profil">
            <img src="/images/cyrille.jpg" alt="Cyrille PIERRE — Retour au profil" class="navbar-avatar">
          </a>
        <% end %>
        <button class="navbar-toggler ms-auto" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-label="Menu">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-1">
            <li class="nav-item">
              <a class="nav-link <%= 'active' if current_page?(root_path) %>" href="<%= root_path %>">Profil</a>
            </li>
            <li class="nav-item">
              <a class="nav-link <%= 'active' if current_page?(operations_path) %>" href="<%= operations_path %>">Excellence Opérationnelle</a>
            </li>
            <li class="nav-item">
              <a class="nav-link <%= 'active' if current_page?(leadership_path) %>" href="<%= leadership_path %>">Leadership</a>
            </li>
            <li class="nav-item">
              <a class="nav-link <%= 'active' if current_page?(tech_path) %>" href="<%= tech_path %>">Tech & IA</a>
            </li>
            <li class="nav-item">
              <a class="nav-link <%= 'active' if current_page?(realisations_path) %>" href="<%= realisations_path %>">Réalisations</a>
            </li>
            <li class="nav-item">
              <a class="nav-link <%= 'active' if current_page?(actus_path) %>" href="<%= actus_path %>">Actus</a>
            </li>
            <li class="nav-item">
              <a class="nav-link <%= 'active' if current_page?(cv_path) %>" href="<%= cv_path %>">CV</a>
            </li>
            <% if user_signed_in? %>
              <li class="nav-item">
                <a class="nav-link <%= 'active' if current_page?(studio_generations_path) %>" href="<%= studio_generations_path %>">Studio</a>
              </li>
              <li class="nav-item">
                <%= button_to "Déconnexion", destroy_user_session_path, method: :delete, class: "nav-link btn-link-as-nav", form: { class: "d-inline" } %>
              </li>
            <% else %>
              <li class="nav-item">
                <a class="nav-link" href="<%= new_user_session_path %>">Connexion</a>
              </li>
            <% end %>
            <li class="nav-item ms-lg-2">
              <% if current_page?(contact_path) %>
                <span class="btn-cp-current">
                  <i class="fa-solid fa-circle-check"></i>
                  Formulaire ouvert
                </span>
              <% else %>
                <a class="btn-cp-primary" href="<%= contact_path %>">Me contacter</a>
              <% end %>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <% unless current_page?(contact_path) %>
      <div class="floating-cta" data-controller="floating-cta">
        <a href="<%= contact_path %>" class="floating-cta-btn">
          <i class="fa-solid fa-paper-plane"></i>
          <span class="floating-cta-label">Me contacter</span>
        </a>
      </div>
    <% end %>

    <main>
      <% if notice.present? %>
        <div class="alert-flash-notice" data-controller="flash"><%= notice %></div>
      <% end %>
      <% if alert.present? %>
        <div class="alert-flash-alert" data-controller="flash"><%= alert %></div>
      <% end %>
      <%= yield %>

      <%
        sections = [
          { label: "Profil",           path: root_path },
          { label: "Excellence Op.",   path: operations_path },
          { label: "Leadership",       path: leadership_path },
          { label: "Tech & IA",        path: tech_path },
          { label: "Réalisations",     path: realisations_path }
        ]
        current_idx = sections.index { |s| current_page?(s[:path]) }
        prev_s = current_idx && current_idx > 0 ? sections[current_idx - 1] : nil
        next_s = current_idx ? sections[current_idx + 1] : nil
      %>
      <% if current_idx %>
        <nav class="section-pagination container" aria-label="Navigation entre sections">
          <div class="section-pagination-inner">
            <% if prev_s %>
              <a href="<%= prev_s[:path] %>" class="section-pagination-link">
                <span class="section-pagination-name">← <%= prev_s[:label] %></span>
              </a>
            <% else %>
              <div></div>
            <% end %>

            <span class="section-pagination-count"><%= current_idx + 1 %> / <%= sections.length %></span>

            <% if next_s %>
              <a href="<%= next_s[:path] %>" class="section-pagination-link section-pagination-link--next">
                <span class="section-pagination-name"><%= next_s[:label] %> →</span>
              </a>
            <% elsif current_idx == sections.length - 1 %>
              <a href="<%= sections.first[:path] %>" class="section-pagination-link section-pagination-link--next">
                <span class="section-pagination-name"><%= sections.first[:label] %> →</span>
              </a>
            <% else %>
              <div></div>
            <% end %>
          </div>
        </nav>
      <% end %>
    </main>

    <footer class="footer-cp">
      <div class="container">
        <div class="row align-items-start g-4">
          <div class="col-md-4">
            <span class="brand-logo">CP</span>
            <span class="footer-name">Cyrille PIERRE</span>
            <p class="footer-tagline">Consultant Indépendant · Ingénieur Arts & Métiers · Lyon</p>
          </div>
          <div class="col-md-4 d-flex align-items-center justify-content-md-center">
            <nav class="footer-nav">
              <a href="<%= root_path %>">Profil</a>
              <a href="<%= operations_path %>">Excellence Op.</a>
              <a href="<%= leadership_path %>">Leadership</a>
              <a href="<%= tech_path %>">Tech & IA</a>
            </nav>
          </div>
          <div class="col-md-4 text-md-end">
            <a href="mailto:cyrille.pierre@gmail.com" class="footer-contact d-block mb-1">cyrille.pierre@gmail.com</a>
            <a href="https://www.linkedin.com/in/cyrille-pierre" target="_blank" rel="noopener" class="footer-contact">LinkedIn → cyrille-pierre</a>
          </div>
        </div>
        <hr class="footer-hr">
        <p class="footer-copy">© <%= Date.current.year %> Cyrille PIERRE · Tous droits réservés</p>
      </div>
    </footer>
  </body>
</html>
