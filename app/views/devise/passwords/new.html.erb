<% content_for :title, "Mot de passe oublié — Cyrille PIERRE" %>

<section class="studio-auth">
  <div class="container">
    <div class="studio-card">
      <h1 class="studio-card-title">Mot de passe oublié</h1>
      <p class="studio-card-sub">Indique ton email pour recevoir les instructions de réinitialisation.</p>

      <%= render "devise/shared/error_messages", resource: resource %>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "cf-fields-grid cf-fields-grid--single" }) do |f| %>
        <div class="cf-field">
          <label class="cf-label" for="user_email">Email</label>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "cf-input", required: true %>
        </div>

        <div class="cf-field">
          <%= f.submit "Envoyer les instructions", class: "btn-cp-primary" %>
        </div>
      <% end %>

      <%= render "devise/shared/links" %>
    </div>
  </div>
</section>
