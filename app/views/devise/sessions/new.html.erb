<% content_for :title, "Connexion — Cyrille PIERRE" %>

<section class="studio-auth">
  <div class="container">
    <div class="studio-card">
      <h1 class="studio-card-title">Connexion</h1>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "cf-fields-grid cf-fields-grid--single" }) do |f| %>
        <div class="cf-field">
          <label class="cf-label" for="user_email">Email</label>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "cf-input", required: true %>
        </div>

        <div class="cf-field">
          <label class="cf-label" for="user_password">Mot de passe</label>
          <%= f.password_field :password, autocomplete: "current-password", class: "cf-input", required: true %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="cf-field cf-field--checkbox">
            <label class="studio-checkbox-label">
              <%= f.check_box :remember_me %>
              Se souvenir de moi
            </label>
          </div>
        <% end %>

        <div class="cf-field">
          <%= f.submit "Se connecter", class: "btn-cp-primary" %>
        </div>
      <% end %>

      <%= render "devise/shared/links" %>
    </div>
  </div>
</section>
